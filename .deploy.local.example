# ============================================================
# 本地发版配置模板 —— 复制为 .deploy.local 并填写你的服务器信息
#   cp .deploy.local.example .deploy.local
#   nano .deploy.local
# .deploy.local 已在 .gitignore，绝不会提交进仓库（服务器地址/端口不外泄）。
# 认证用 SSH 密钥（本机 ~/.ssh 里的私钥），不放密码。
# ============================================================

# ---- 方式一（推荐）：在 ~/.ssh/config 里配好 Host 别名，这里只填别名 ----
# 例如 ~/.ssh/config 里：
#   Host tonghui-prod
#     HostName 47.100.20.30
#     User root
#     Port 22
#     IdentityFile ~/.ssh/id_ed25519
# 然后这里填别名即可（填了别名，下面方式二的 HOST/USER/PORT/KEY 全部忽略）：
DEPLOY_SSH_ALIAS=

# ---- 方式二：直接填服务器信息（没配 ssh/config 用这个）----
DEPLOY_HOST=              # 服务器公网 IP 或域名，如 47.100.20.30
DEPLOY_USER=root         # SSH 登录用户（要能跑 docker：root，或已加入 docker 组/免密 sudo 的用户）
DEPLOY_PORT=22           # SSH 端口，默认 22
DEPLOY_KEY=              # 私钥路径，如 ~/.ssh/id_ed25519；留空=用默认私钥 / ssh-agent

# ---- 通用 ----
DEPLOY_PATH=/opt/excel-share-system   # 服务器上项目目录（git clone 所在，含 docker-compose.prod.yml）
DEPLOY_BRANCH=main                    # 部署分支，默认 main
