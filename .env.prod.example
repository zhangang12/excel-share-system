# 生产环境配置——复制为 .env.prod 并修改！

# PostgreSQL
POSTGRES_USER=pms_prod
POSTGRES_PASSWORD=请改为长随机字符串
POSTGRES_DB=pms

# Backend 安全
# ⚠️ 必须改！用 openssl rand -hex 32 生成
SECRET_KEY=必须替换为 64 位随机十六进制字符串

# 默认管理员（首次启动用，登录后立刻改）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ⚠️ 文件存储目录——必须与 docker-compose.prod.yml volumes 挂载一致
# uploads_data 卷挂载到 /app/uploads，此行不可修改，否则容器重建后上传文件全部丢失
FILES_DIR=/app/uploads

# 销售下单审批（true=销售员下单需主管审批；false=直接生效）
SALES_ORDER_APPROVAL=true
