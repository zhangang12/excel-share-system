# ===== Python =====
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.venv-build/

# ===== Node =====
node_modules/
dist/
.vite/
*.tsbuildinfo

# ===== 构建产物 =====
build/build/
build/out/

# ===== 运行时数据 / 数据库 =====
data/
*.db
*.sqlite
*.sqlite3

# ===== 环境变量（保留 .env.example / .env.prod.example 模板）=====
.env
.env.*
!.env.example
!.env.prod.example

# ===== 本地发版配置（服务器地址/端口，保留 .deploy.local.example 模板）=====
.deploy.local

# ===== IDE / 工具 =====
.idea/
.vscode/
.claude/
*.swp

# ===== 日志 =====
*.log

# ===== OS =====
.DS_Store
Thumbs.db

# ===== 打包 / 临时压缩包 =====
*.zip
*.tar.gz
*.7z
*.rar

# ===== HTTPS 证书 / ACME（私钥绝不入库；目录保留 .gitkeep）=====
nginx/certs/*
!nginx/certs/.gitkeep
nginx/letsencrypt/
nginx/certbot-www/*
!nginx/certbot-www/.gitkeep
nginx/wecom-verify/*
!nginx/wecom-verify/.gitkeep
nginx/conf.d/*.bak
nginx/conf.d/default.conf.pre-https.bak.*
